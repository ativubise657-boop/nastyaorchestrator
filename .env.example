# Шаблон переменных окружения Nastya Orchestrator
# Скопируй в .env и заполни реальными значениями:
#   cp .env.example .env

# ─── Аутентификация ──────────────────────────────────────────────────────────
# Токен для воркеров (Bearer token в заголовке Authorization)
# Генерация: python3 -c "import secrets; print(secrets.token_hex(32))"
WORKER_TOKEN=сгенерировать-случайный-токен-64-символа

# Путь к Codex CLI. На Windows с проблемным WindowsApps лучше использовать локальный wrapper.
# Для этого репозитория безопасный вариант: `tools\codex-npx.cmd`.
CODEX_BINARY=tools\codex-npx.cmd

# AI Tunnel API для моделей GLM / GPT через OpenAI-compatible endpoint.
# Ключ выдаётся в AI Tunnel, базовый URL по умолчанию подходит для production.
AITUNNEL_API_KEY=
AITUNNEL_BASE_URL=https://api.aitunnel.ru/v1
AITUNNEL_REQUEST_TIMEOUT=120
AITUNNEL_MAX_TOOL_ROUNDS=16

# ─── Директории ──────────────────────────────────────────────────────────────
# Корневая директория данных
DATA_DIR=/opt/nastya-orch/data

# Директория загруженных документов
DOCUMENTS_DIR=/opt/nastya-orch/data/documents

# ─── Bitrix24 CRM ────────────────────────────────────────────────────────────
# Webhook для запросов к CRM (компании, клиенты, контакты)
# Создать: Б24 → Разработчикам → Входящий webhook → права crm.*
BITRIX_WEBHOOK_URL=https://ваш-портал.bitrix24.ru/rest/USER_ID/TOKEN/

# ─── Блокнот (хранилище заметок) ─────────────────────────────────────────────
# Путь к папке заметок (Obsidian vault / storage)
# По умолчанию: data/notes внутри проекта
# NOTES_PATH=C:\Users\USERNAME\Documents\notes

# ─── Git ─────────────────────────────────────────────────────────────────────
# GitHub PAT для клонирования приватных репо (fine-grained token)
# Настрой: github.com → Settings → Developer settings → Fine-grained tokens
GITHUB_PAT=ghp_ваш_токен_здесь

# Если обновление приложения идёт через SSH-ключ и на машине несколько ключей,
# можно явно указать команду для Git:
# APP_GIT_SSH_COMMAND=ssh -i C:/Users/USERNAME/.ssh/id_ed25519 -o IdentitiesOnly=yes -o BatchMode=yes
